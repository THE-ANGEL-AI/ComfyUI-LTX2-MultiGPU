# ─── EOL normalization (LF for source files) ────────────────────────
# Default: detect per-text-file; binary otherwise
* text=auto

# Force LF for source code & textual config (avoids diff noise on Windows)
*.py        text eol=lf
*.md        text eol=lf
*.toml      text eol=lf
*.txt       text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
*.js        text eol=lf
*.ts        text eol=lf

# Repo metadata + ignore files themselves stay LF
.gitignore      text eol=lf
.gitattributes  text eol=lf
 LICENSE        text eol=lf

# Binary (should stay that way)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.tar   binary
*.gz    binary

# --- UTF-8 hardlock for source files (multi-language safe) ---
*.py   working-tree-encoding=UTF-8
*.toml working-tree-encoding=UTF-8
*.md   working-tree-encoding=UTF-8
 LICENSE working-tree-encoding=UTF-8
*.json working-tree-encoding=UTF-8
*.yaml working-tree-encoding=UTF-8
*.yml  working-tree-encoding=UTF-8
*.txt  working-tree-encoding=UTF-8
*.cfg  working-tree-encoding=UTF-8
*.ini  working-tree-encoding=UTF-8
